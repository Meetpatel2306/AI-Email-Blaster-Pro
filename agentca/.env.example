# ── App ──
APP_ENV=development
APP_DEBUG=true
APP_BASE_URL=http://localhost:8000

# ── Supabase (FREE) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── WhatsApp Business Cloud API (FREE — Meta Direct) ──
WHATSAPP_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_VERIFY_TOKEN=agentca_verify_2026
WHATSAPP_APP_SECRET=your-meta-app-secret

# ── Groq (FREE — Primary AI) ──
GROQ_API_KEY=your-groq-api-key

# ── Google Gemini (FREE — Fallback AI + OCR) ──
GEMINI_API_KEY=your-gemini-api-key

# ── Upstash Redis (FREE — Rate Limiting) ──
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-token

# ── Sentry (FREE — Error Tracking) ──
SENTRY_DSN=https://your-sentry-dsn

# ── PostHog (FREE — Analytics) ──
POSTHOG_API_KEY=your-posthog-key
POSTHOG_HOST=https://app.posthog.com

# ── Razorpay (Phase 2 — Subscriptions) ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
